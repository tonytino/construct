# Anthropic API key (https://platform.claude.com/ -> API keys)
ANTHROPIC_API_KEY=sk-ant-...

# Slack bot token for your standup Slack app (xoxb-...).
# Required scopes: chat:write, channels:read, channels:history, users:read, im:write
# (add groups:read + groups:history if the standup channel is private)
SLACK_BOT_TOKEN=xoxb-...

# Channel the standup is posted in (channel ID, not name)
SLACK_CHANNEL_ID=C0123456789

# Your Slack user ID — receives blocker DMs and the end-of-window digest
STANDUP_OWNER_SLACK_ID=U0123456789

# Optional overrides (defaults shown). Cron is minute hour dom month dow.
# STANDUP_TZ=America/Los_Angeles
# STANDUP_CRON_POST=0 9 * * 1-5
# STANDUP_CRON_REMIND=30 10 * * 1-5
# STANDUP_CRON_FINAL=0 12 * * 1-5
